{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install --prefix apps/api"
  },
  "deploy": {
    "startCommand": "node apps/api/server.js",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
