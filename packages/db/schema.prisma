generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Creator {
  id                   String     @id @default(cuid())
  email                String     @unique
  robloxUserId         String?
  robloxUsername        String?
  robloxDisplayName    String?
  robloxAccessToken    String?    @db.Text
  robloxRefreshToken   String?    @db.Text
  robloxTokenExpiresAt DateTime?
  robloxApiKey         String?    @db.Text
  stripeId             String?
  plan                 String     @default("free")
  autopilot            Boolean    @default(false)
  timezone             String     @default("UTC")
  games                Game[]
  agentRuns            AgentRun[]
  createdAt            DateTime   @default(now())
}

model Game {
  id           String            @id @default(cuid())
  creatorId    String
  robloxGameId String            @unique
  name         String
  genre        String[]
  healthScore  Int               @default(50)
  competitors  String[]
  creator      Creator           @relation(fields: [creatorId], references: [id])
  snapshots    MetricSnapshot[]
  priceTests   PriceTest[]
  tickets      SupportTicket[]
  content      ContentPiece[]
  bugs         BugTicket[]
}

model MetricSnapshot {
  id               String   @id @default(cuid())
  gameId           String
  date             DateTime
  dau              Int
  mau              Int
  concurrentPeak   Int
  avgSessionSec    Int
  retentionD1      Float
  retentionD7      Float
  retentionD30     Float
  robuxEarned      Int
  newPlayers       Int
  returningPlayers Int
  topItems         Json
  visitSources     Json
  game             Game     @relation(fields: [gameId], references: [id])
}

model PriceTest {
  id          String    @id @default(cuid())
  gameId      String
  itemId      String
  itemName    String
  priceA      Int
  priceB      Int
  exposuresA  Int       @default(0)
  exposuresB  Int       @default(0)
  revenueA    Int       @default(0)
  revenueB    Int       @default(0)
  status      String    @default("running")
  winner      String?
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  game        Game      @relation(fields: [gameId], references: [id])
}

model SupportTicket {
  id           String   @id @default(cuid())
  gameId       String
  playerId     String
  category     String
  message      String
  response     String?
  status       String   @default("open")
  robuxValue   Int?
  autoResolved Boolean  @default(false)
  game         Game     @relation(fields: [gameId], references: [id])
  createdAt    DateTime @default(now())
}

model ContentPiece {
  id           String    @id @default(cuid())
  gameId       String?
  creatorId    String?
  type         String
  platform     String?
  content      String
  qualityScore Int?
  status       String    @default("draft")
  performance  Json?
  sourceData   Json?
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  game         Game?     @relation(fields: [gameId], references: [id])
}

model AgentRun {
  id                 String    @id @default(cuid())
  creatorId          String
  agentName          String
  gameId             String?
  input              Json
  output              Json
  action             String
  robuxImpact        Int?
  actualRobuxImpact  Int?
  baselineMetrics    Json?
  followUpAt         DateTime?
  followUpCompleted  Boolean   @default(false)
  status             String    @default("success")
  createdAt          DateTime  @default(now())
  creator            Creator   @relation(fields: [creatorId], references: [id])
}

model CompetitorSnapshot {
  id             String   @id @default(cuid())
  watchingGameId String
  robloxGameId   String
  name           String
  concurrent     Int
  rating         Float
  updatedAt      DateTime @default(now())
}

model BugTicket {
  id          String   @id @default(cuid())
  gameId      String
  description String
  reportCount Int      @default(1)
  status      String   @default("open")
  game        Game     @relation(fields: [gameId], references: [id])
  createdAt   DateTime @default(now())
}

model PlayerSentiment {
  id                   String   @id @default(cuid())
  gameId               String
  analyzedAt           DateTime @default(now())
  topBugs              Json
  topRequests          Json
  topPraise            Json
  topFrustrations      Json
  overallScore         Int
  weekOverWeekChange   String   @default("neutral")
  claudeSummary        String?
  ticketsAnalyzed      Int      @default(0)
}

model EventImpact {
  id               String   @id @default(cuid())
  gameId           String
  eventType        String
  eventName        String
  startedAt        DateTime
  measuredAt       DateTime?
  dauBefore        Int      @default(0)
  dauAfter         Int      @default(0)
  dauChangePercent Float    @default(0)
  retentionBefore  Float    @default(0)
  retentionAfter   Float    @default(0)
  revenueBefore    Int      @default(0)
  revenueAfter     Int      @default(0)
  sessionBefore    Int      @default(0)
  sessionAfter     Int      @default(0)
  verdict          String   @default("pending")
  claudeSummary    String?
  measured         Boolean  @default(false)
}

model RevenueForecast {
  id                String   @id @default(cuid())
  creatorId         String
  gameId            String
  forecastDate      DateTime @default(now())
  next30DaysRobux   Int
  next90DaysRobux   Int
  projectedDevExUSD Float
  upsideRobux       Int
  downsideRobux     Int
  assumptions       Json
  seasonalFactors   Json
}

model MentionLog {
  id              String   @id @default(cuid())
  mentionId       String   @unique
  authorId        String
  authorUsername  String
  authorFollowers Int      @default(0)
  content         String
  category        String
  replyDrafted    String?
  replyPosted     Boolean  @default(false)
  replyTweetId    String?
  processedAt     DateTime @default(now())
}

model XOutreachLog {
  id              String    @id @default(cuid())
  tweetId         String    @unique
  authorId        String
  authorUsername   String
  tweetContent    String
  category        String
  replyDrafted    String?
  replyPosted     Boolean   @default(false)
  postedAt        DateTime?
  tweetUrl        String?
  replyUrl        String?
  createdAt       DateTime  @default(now())
}

model KeyValue {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
